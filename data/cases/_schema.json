{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/entrepreneur-case.schema.json",
  "title": "Entrepreneur Case Report",
  "type": "object",
  "required": [
    "schema_version",
    "case_context",
    "founder_company_context",
    "core_product_cases",
    "recruitment_signals",
    "official_site_signals",
    "future_bets",
    "sources"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "case_context": {
      "type": "object",
      "required": ["case_name", "slug", "case_type", "learning_objective", "first_principle"],
      "properties": {
        "case_name": { "type": "string" },
        "slug": { "type": "string" },
        "case_type": {
          "type": "string",
          "enum": ["product_company_case", "platform_company_case", "person_method_case", "gtm_comparison_case"]
        },
        "learning_objective": { "type": "string" },
        "first_principle": { "type": "string" },
        "target_reader": { "type": "string" },
        "evidence_boundary": { "type": "string" }
      }
    },
    "founder_company_context": {
      "type": "object",
      "required": ["founder_profiles", "capital_history"],
      "properties": {
        "founder_profiles": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "role", "summary", "links"],
            "properties": {
              "name": { "type": "string" },
              "role": { "type": "string" },
              "summary": { "type": "string" },
              "links": { "type": "array", "items": { "$ref": "#/$defs/source" } },
              "confidence": { "$ref": "#/$defs/confidence" }
            }
          }
        },
        "capital_history": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["date", "event_type", "description", "sources", "confidence"],
            "properties": {
              "date": { "type": "string" },
              "event_type": { "type": "string" },
              "amount": { "type": "string" },
              "currency": { "type": "string" },
              "description": { "type": "string" },
              "sources": { "type": "array", "items": { "$ref": "#/$defs/source" } },
              "confidence": { "$ref": "#/$defs/confidence" }
            }
          }
        }
      }
    },
    "core_product_cases": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": [
          "name",
          "case_role",
          "status",
          "why_developed",
          "original_pain",
          "development_difficulties",
          "commercialization_path",
          "pricing_stack",
          "return_evidence",
          "roi_assessment"
        ],
        "properties": {
          "name": { "type": "string" },
          "case_role": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["verified_core", "core_hypothesis", "market_expansion", "strategic_experiment", "failure_boundary", "platform_layer"]
          },
          "why_developed": { "type": "string" },
          "original_pain": { "type": "string" },
          "why_incumbents_failed": { "type": "string" },
          "development_difficulties": { "type": "array", "items": { "$ref": "#/$defs/evidence_note" } },
          "development_costs": { "type": "array", "items": { "$ref": "#/$defs/evidence_note" } },
          "commercialization_path": { "type": "array", "items": { "$ref": "#/$defs/evidence_note" } },
          "pricing_stack": {
            "type": "object",
            "required": ["product_price", "accessory_service", "subscription_software", "competitor_prices"],
            "properties": {
              "product_price": { "$ref": "#/$defs/evidence_note" },
              "accessory_service": { "$ref": "#/$defs/evidence_note" },
              "subscription_software": { "$ref": "#/$defs/evidence_note" },
              "competitor_prices": {
                "type": "array",
                "items": { "$ref": "#/$defs/evidence_note" }
              }
            }
          },
          "return_evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence_note" } },
          "roi_assessment": {
            "type": "object",
            "required": ["calculable", "known_inputs", "missing_inputs", "conclusion"],
            "properties": {
              "calculable": { "type": "boolean" },
              "formula": { "type": "string" },
              "known_inputs": { "type": "array", "items": { "$ref": "#/$defs/evidence_note" } },
              "missing_inputs": { "type": "array", "items": { "type": "string" } },
              "conclusion": { "type": "string" }
            }
          },
          "entrepreneur_lessons": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "recruitment_signals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["signal", "evidence_status", "source", "inferred_direction", "confidence", "validation_needed"],
        "properties": {
          "signal": { "type": "string" },
          "evidence_status": {
            "type": "string",
            "enum": ["observed_job_post", "job_board_index", "watchlist_not_yet_captured"]
          },
          "source": { "$ref": "#/$defs/source" },
          "capability_gap": { "type": "string" },
          "inferred_direction": { "type": "string" },
          "confidence": { "$ref": "#/$defs/confidence" },
          "validation_needed": { "type": "string" }
        }
      }
    },
    "official_site_signals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["signal", "source", "insight", "confidence"],
        "properties": {
          "signal": { "type": "string" },
          "source": { "$ref": "#/$defs/source" },
          "insight": { "type": "string" },
          "confidence": { "$ref": "#/$defs/confidence" }
        }
      }
    },
    "future_bets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["bet", "why_it_matters", "supporting_signals", "confidence", "watch_next"],
        "properties": {
          "bet": { "type": "string" },
          "why_it_matters": { "type": "string" },
          "supporting_signals": { "type": "array", "items": { "type": "string" } },
          "confidence": { "$ref": "#/$defs/confidence" },
          "watch_next": { "type": "string" }
        }
      }
    },
    "sources": {
      "type": "array",
      "items": { "$ref": "#/$defs/source" }
    }
  },
  "$defs": {
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "source": {
      "type": "object",
      "required": ["label", "url"],
      "properties": {
        "label": { "type": "string" },
        "url": { "type": "string" },
        "publisher": { "type": "string" },
        "used_for": { "type": "string" }
      }
    },
    "evidence_note": {
      "type": "object",
      "required": ["label", "value", "source", "confidence"],
      "properties": {
        "label": { "type": "string" },
        "value": { "type": "string" },
        "source": { "$ref": "#/$defs/source" },
        "confidence": { "$ref": "#/$defs/confidence" }
      }
    }
  }
}
